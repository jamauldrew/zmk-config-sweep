&flash0 {
 reg = <0x00000000 ((1024) * 1024)>;
};

&sram0 {
 reg = <0x20000000 ((256) * 1024)>;
};

&power {
 reg0: regulator@40000580 {
  compatible = "nordic,nrf52x-regulator-hv";
  reg = <0x40000580 0x1>;
  regulator-name = "REG0";
  status = "disabled";
 };
};

/ {
 soc {
  compatible = "nordic,nrf52840-qiaa", "nordic,nrf52840",
        "nordic,nrf52", "simple-bus";
 };
};
# 10 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/nice_nano.dts" 2 3 4
# 1 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/nice_nano-pinctrl.dtsi" 1 3 4





&pinctrl {
    uart0_default: uart0_default {
        group1 {
            psels = <((((((0) * 32U) + (8)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>;
            bias-pull-up;
        };
        group2 {
            psels = <((((((0) * 32U) + (6)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <((((((0) * 32U) + (8)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (6)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };

    i2c0_default: i2c0_default {
        group1 {
            psels = <((((((0) * 32U) + (17)) & 0x1FFU) << 0U) | ((12U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (20)) & 0x1FFU) << 0U) | ((11U & 0xFFU) << 24U))>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <((((((0) * 32U) + (17)) & 0x1FFU) << 0U) | ((12U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (20)) & 0x1FFU) << 0U) | ((11U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };

    spi1_default: spi1_default {
        group1 {
            psels = <((((((1) * 32U) + (13)) & 0x1FFU) << 0U) | ((4U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (10)) & 0x1FFU) << 0U) | ((5U & 0xFFU) << 24U))>,
                <((((((1) * 32U) + (11)) & 0x1FFU) << 0U) | ((6U & 0xFFU) << 24U))>;
        };
    };

    spi1_sleep: spi1_sleep {
        group1 {
            psels = <((((((1) * 32U) + (13)) & 0x1FFU) << 0U) | ((4U & 0xFFU) << 24U))>,
                <((((((0) * 32U) + (10)) & 0x1FFU) << 0U) | ((5U & 0xFFU) << 24U))>,
                <((((((1) * 32U) + (11)) & 0x1FFU) << 0U) | ((6U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };
};
# 11 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/nice_nano.dts" 2 3 4
# 1 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/arduino_pro_micro_pins.dtsi" 1 3 4






/ {
    pro_micro: connector {
        compatible = "arduino-pro-micro";
        #gpio-cells = <2>;
        gpio-map-mask = <0xffffffff 0xffffffc0>;
        gpio-map-pass-thru = <0 0x3f>;
        gpio-map
            = <0 0 &gpio0 8 0>
            , <1 0 &gpio0 6 0>
            , <2 0 &gpio0 17 0>
            , <3 0 &gpio0 20 0>
            , <4 0 &gpio0 22 0>
            , <5 0 &gpio0 24 0>
            , <6 0 &gpio1 0 0>
            , <7 0 &gpio0 11 0>
            , <8 0 &gpio1 4 0>
            , <9 0 &gpio1 6 0>
            , <10 0 &gpio0 9 0>
            , <16 0 &gpio0 10 0>
            , <14 0 &gpio1 11 0>
            , <15 0 &gpio1 13 0>
            , <18 0 &gpio1 15 0>
            , <19 0 &gpio0 2 0>
            , <20 0 &gpio0 29 0>
            , <21 0 &gpio0 31 0>
            ;
    };

    pro_micro_a: connector_a {
        compatible = "arduino-pro-micro";
        #gpio-cells = <2>;
        gpio-map-mask = <0xffffffff 0xffffffc0>;
        gpio-map-pass-thru = <0 0x3f>;
        gpio-map
            = <0 0 &gpio1 15 0>
            , <1 0 &gpio0 2 0>
            , <2 0 &gpio0 29 0>
            , <3 0 &gpio0 31 0>
            , <6 0 &gpio0 22 0>
            , <7 0 &gpio1 0 0>
            , <8 0 &gpio1 4 0>
            , <9 0 &gpio1 6 0>
            , <10 0 &gpio0 9 0>
            ;
    };
};

pro_micro_d: &pro_micro {};
pro_micro_i2c: &i2c0 {};
pro_micro_spi: &spi1 {};
pro_micro_serial: &uart0 {};
# 12 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/nice_nano.dts" 2 3 4


/ {
    model = "nice!nano";
    compatible = "nice,nano";

    chosen {
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
    };

    leds {
        compatible = "gpio-leds";
        blue_led: led_0 {
            gpios = <&gpio0 15 (0 << 0)>;
        };
    };
};

&reg1 {
    regulator-initial-mode = <1>;
};

&adc {
    status = "okay";
};

&gpiote {
    status = "okay";
};

&gpio0 {
    status = "okay";
};

&gpio1 {
    status = "okay";
};

&i2c0 {
    compatible = "nordic,nrf-twi";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
};

&spi1 {
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
};

&uart0 {
    compatible = "nordic,nrf-uarte";
    current-speed = <115200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

zephyr_udc0: &usbd {
    status = "okay";
};


&flash0 {




    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            reg = <0x00000000 0x00026000>;
        };
        code_partition: partition@26000 {
            reg = <0x00026000 0x000c6000>;
        };
# 105 "/zmk-config-sweep/zmk/app/module/boards/nicekeyboards/nice_nano/nice_nano.dts" 3 4
        storage_partition: partition@ec000 {
            reg = <0x000ec000 0x00008000>;
        };

        boot_partition: partition@f4000 {
            reg = <0x000f4000 0x0000c000>;
        };
    };
};
# 10 "/zmk-config-sweep/zmk/app/boards/nicekeyboards/nice_nano/nice_nano_nrf52840_zmk.dts" 2
# 1 "/zmk-config-sweep/zmk/app/dts/common/nordic/nrf52840_uf2_boot_mode.dtsi" 1 3 4

&gpregret1 {
    adafruit_boot_retention: retention@0 {
        compatible = "zephyr,retention";
        status = "okay";
        reg = <0x0 0x1>;
    };
};

/ {
    chosen {
        zephyr,boot-mode = &boot_retention;
        zmk,magic-boot-mode = &adafruit_boot_retention;
    };

    magic_mapper {
        compatible = "zmk,bootmode-to-magic-mapper";
        status = "okay";

        #address-cells = <1>;
        #size-cells = <1>;

        boot_retention: retention@0 {
            compatible = "zephyr,retention";
            status = "okay";
            reg = <0x0 0x1>;
        };
    };
};
